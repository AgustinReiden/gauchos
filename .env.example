# GauchOS Voice Agent — Environment Variables

# ── AI Services ──────────────────────────────────────────
DEEPGRAM_API_KEY=           # Deepgram API key (STT)
CARTESIA_API_KEY=           # Cartesia API key (TTS)
GEMINI_API_KEY=             # Google Gemini API key (LLM)

# ── Transport ────────────────────────────────────────────
DAILY_API_KEY=              # Daily.co API key (WebRTC transport)

# ── GauchOS Backend ──────────────────────────────────────
GAUCHOSHQ_EDGE_URL=         # e.g., https://xxx.supabase.co/functions/v1/voice-agent-handler
GAUCHOSHQ_EDGE_KEY=         # API key for the Edge Function
ESTABLECIMIENTO_ID=         # UUID of the establecimiento
